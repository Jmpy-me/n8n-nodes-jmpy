{
  "name": "n8n-nodes-jmpy",
  "version": "2.0.1",
  "description": "n8n community node for Jmpy.me URL shortener and QR generator",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://jmpy.me",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jmpy-me/n8n-nodes-jmpy.git"
  },
  "bugs": {
    "url": "https://github.com/Jmpy-me/n8n-nodes-jmpy/issues"
  },
  "author": {
    "name": "Jmpy.me",
    "email": "support@jmpy.me"
  },
  "main": "dist/nodes/Jmpy/Jmpy.node.js",
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/JmpyOAuth2Api.credentials.js"
