    "nodes": [
      "dist/nodes/Jmpy/Jmpy.node.js",
      "dist/nodes/Jmpy/JmpyTrigger.node.js",
      "dist/nodes/Jmpy/JmpyPollingTrigger.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "@types/node": "^18.16.0",
    "n8n": "^2.28.6",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.2.2"
  }
}
